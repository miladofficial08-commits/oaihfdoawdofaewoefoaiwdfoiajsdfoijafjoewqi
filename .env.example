# ─── Scraper ─────────────────────────────────────────────────────────────────
# Wähle einen der beiden:
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx   # empfohlen, free tier reicht
APIFY_GOOGLE_MAPS_ACTOR=compass/crawler-google-places
# SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx        # Alternative

# ─── AI (Claude Haiku — nur für A/B Leads, günstigster Tier) ─────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5-nano
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server (Approval Dashboard) ─────────────────────────────────────────────
# PORT is injected automatically by Railway — do NOT set it there manually.
# Locally the server falls back to 4000.
# PORT=4000

# Main dashboard storage. On Railway, mount a persistent volume at /data.
# For a custom file path, SQLITE_DB_PATH wins over DATA_DIR.
DATA_DIR=./data
# SQLITE_DB_PATH=/data/leads.db

# HOST defaults to 0.0.0.0 (required for Railway). Override locally if needed:
# HOST=127.0.0.1

# Dashboard login — keep secret, never commit a real value.
ADMIN_PASSWORD=change-this-admin-password

# ─── Tracking (Öffnungen + Klicks) ──────────────────────────────────────────
# Set to your Railway public URL after first deploy, e.g.:
# PUBLIC_BASE_URL=https://leadgen-production.up.railway.app
PUBLIC_BASE_URL=

# ─── SMTP (ausgehende Mails) ─────────────────────────────────────────────────
SMTP_HOST=smtps.example.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=info@example.de
SMTP_PASS=change-me
SMTP_FROM="Tawano <info@example.de>"
CONTACT_RECEIVER=info@example.de

# ─── IMAP (eingehende Mails — Antworten lesen) ───────────────────────────────
IMAP_HOST=imap.example.de
IMAP_PORT=993
IMAP_SECURE_SSL=true
IMAP_USER=info@example.de
IMAP_PASS=change-me

# ─── SMS-Statistik (optional, read-only Supabase) ────────────────────────────
SMS_SUPABASE_URL=
SMS_SUPABASE_KEY=
